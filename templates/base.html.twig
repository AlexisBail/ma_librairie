<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Ma Librairie{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {% block stylesheets %}
            <style>
                /* Style pour matcher avec ton Dashboard EasyAdmin */
                body { background-color: #121212; color: #ffffff; font-family: sans-serif; }
                .navbar { background-color: #1a1a1a !important; border-bottom: 1px solid #333 !important; }
                .nav-link-admin { color: #0dcaf0 !important; font-weight: bold; text-decoration: none; }
                .container { margin-top: 30px; }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="padding: 10px 20px;">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="{{ path('app_produit') }}">📚 LIBRAIRIE</a>
            
            <div class="ms-auto d-flex align-items-center">
                {% if app.user %}
                    <span class="text-secondary me-3 small">Connecté : <strong>{{ app.user.email }}</strong></span>
                    
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin') }}" class="nav-link-admin me-3">
                            ⚙️ Dashboard
                        </a>
                    {% endif %}
                    
                    <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">Se connecter</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <div class="container">
        {% block body %}
        {% endblock %}
    </div>
    </body>
</html>
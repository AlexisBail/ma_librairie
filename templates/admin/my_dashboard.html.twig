{# templates/admin/my_dashboard.html.twig #}
{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de Bord - Statistiques{% endblock %}

{% block main %}
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white mb-4 shadow">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-book fa-3x me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Total Livres</h5>
                        <h2 class="display-6 fw-bold mb-0">{{ stats.countProduits }}</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-success text-white mb-4 shadow">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-users fa-3x me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Membres Inscrits</h5>
                        <h2 class="display-6 fw-bold mb-0">{{ stats.countUsers }}</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-warning text-dark mb-4 shadow">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-euro-sign fa-3x me-3"></i>
                    <div>
                        <h5 class="card-title mb-0">Valeur Stock</h5>
                        <h2 class="display-6 fw-bold mb-0">{{ stats.totalPrix|number_format(2, ',', ' ') }} €</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <p class="text-secondary italic">Bienvenue dans votre gestionnaire de librairie. Utilisez le menu à gauche pour gérer vos données.</p>
    </div>
{% endblock %}